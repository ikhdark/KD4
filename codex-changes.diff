+        .map(loadable_tool_spec_diversity_key)
+        .collect::<HashSet<_>>()
+        .len()
+}
+
+fn loadable_tool_spec_diversity_key(spec: &LoadableToolSpec) -> ToolSearchDiversityKey<'_> {
+    match spec {
