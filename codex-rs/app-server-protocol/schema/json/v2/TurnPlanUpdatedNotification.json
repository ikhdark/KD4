{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "TurnPlanStep": {
      "properties": {
        "acceptanceCriteria": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "dependsOn": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "generatedArtifacts": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "id": {
          "type": [
            "string",
            "null"
          ]
        },
        "requiresDesktopActivation": {
          "default": false,
          "type": "boolean"
        },
        "risks": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "runtimePaths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "status": {
          "$ref": "#/definitions/TurnPlanStepStatus"
        },
        "step": {
          "type": "string"
        }
      },
      "required": [
        "status",
        "step"
      ],
      "type": "object"
    },
    "TurnPlanStepStatus": {
      "enum": [
        "pending",
        "inProgress",
        "implemented",
        "passed",
        "blocked",
        "skipped",
        "completed"
      ],
      "type": "string"
    }
  },
  "properties": {
    "explanation": {
      "type": [
        "string",
        "null"
      ]
    },
    "plan": {
      "items": {
        "$ref": "#/definitions/TurnPlanStep"
      },
      "type": "array"
    },
    "threadId": {
      "type": "string"
    },
    "turnId": {
      "type": "string"
    }
  },
  "required": [
    "plan",
    "threadId",
    "turnId"
  ],
  "title": "TurnPlanUpdatedNotification",
  "type": "object"
}